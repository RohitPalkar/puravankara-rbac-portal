NODE_ENV=development
PORT=3000

# Database — replace with your connection string or individual params
DATABASE_URL=postgresql://user:password@localhost:5432/puravankara_rbac_v3

# JWT secrets — generate with: openssl rand -base64 32
JWT_SECRET=change-me-to-a-random-secret
JWT_REFRESH_SECRET=change-me-to-another-random-secret

# Default admin credentials (used by bootstrap seeder)
DEFAULT_ADMIN_EMAIL=admin@puravankara.com
DEFAULT_ADMIN_PASSWORD=Admin@12345

# Optional overrides
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=postgres
# DB_NAME=puravankara_rbac_v3
# DB_POOL_MAX=10
# DB_LOGGING=false
# TYPEORM_SYNC=false

# Redis (optional, for session caching)
# REDIS_ENABLED=false
# REDIS_URL=redis://localhost:6379

# CORS
# CORS_ORIGINS=http://localhost:5173,http://localhost:5174
# FRONTEND_URL=http://localhost:5173

# Throttling
# THROTTLE_TTL=60
# THROTTLE_LIMIT=100
